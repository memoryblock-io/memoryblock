{
  "name": "memoryblock",
  "version": "0.1.10",
  "type": "module",
  "description": "Deploy isolated, multi-agent AI assistants on your local machine with extreme resource efficiency.",
  "main": "./dist/entry.js",
  "types": "./dist/entry.d.ts",
  "files": [
    "dist/",
    "bin/"
  ],
  "bin": {
    "mblk": "./bin/mblk.js"
  },
  "exports": {
    ".": {
      "types": "./dist/entry.d.ts",
      "import": "./dist/entry.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "postinstall": "node ./bin/postinstall.js"
  },
  "dependencies": {
    "@memoryblock/core": "workspace:*",
    "@memoryblock/types": "workspace:*",
    "@memoryblock/locale": "workspace:*",
    "@memoryblock/daemon": "workspace:*",
    "@memoryblock/api": "workspace:*",
    "@memoryblock/tools": "workspace:*",
    "@memoryblock/adapters": "workspace:*",
    "@memoryblock/channels": "workspace:*",
    "@memoryblock/web": "workspace:*",
    "@memoryblock/plugin-agents": "workspace:*",
    "@memoryblock/plugin-installer": "workspace:*",
    "@memoryblock/plugin-web-search": "workspace:*",
    "@memoryblock/plugin-fetch-webpage": "workspace:*",
    "@clack/prompts": "^1.3.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "memoryblock",
    "mblk",
    "ai-agent",
    "assistants",
    "agents",
    "automation",
    "multi-agent",
    "agentic-framework",
    "core",
    "cli",
    "framework",
    "interface",
    "channels",
    "adapters",
    "tools",
    "skills",
    "local-ai",
    "local-llm",
    "openai",
    "anthropic",
    "gemini",
    "groq",
    "chatgpt",
    "deepseek",
    "ollama"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoryblock-io/memoryblock.git"
  },
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}