{
  "name": "memoryblock",
  "version": "0.1.1-beta",
  "type": "module",
  "description": "Deploy isolated, multi-agent AI assistants on your local machine with extreme resource efficiency.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mblk": "./bin/mblk.js",
    "memoryblock": "./bin/mblk.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@memoryblock/daemon": "workspace:*",
    "@memoryblock/adapters": "workspace:*",
    "@memoryblock/channels": "workspace:*",
    "@memoryblock/tools": "workspace:*",
    "@memoryblock/api": "workspace:*",
    "@memoryblock/web": "workspace:*",
    "@memoryblock/locale": "workspace:*",
    "@memoryblock/plugin-installer": "workspace:*",
    "@memoryblock/plugin-agents": "workspace:*",
    "@clack/prompts": "^1.1.0",
    "commander": "^13.0.0",
    "chalk": "^5.4.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@memoryblock/plugin-web-search": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "memoryblock",
    "mblk",
    "ai-agent",
    "assistants",
    "agents",
    "automation",
    "multi-agent",
    "agentic-framework",
    "core",
    "framework",
    "interface",
    "channels",
    "adapters",
    "tools",
    "skills",
    "local-ai",
    "local-llm",
    "openai",
    "anthropic",
    "gemini",
    "groq",
    "chatgpt",
    "deepseek",
    "ollama"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoryblock-io/memoryblock.git"
  },
  "bugs": {
    "url": "https://github.com/memoryblock-io/memoryblock/issues"
  },
  "homepage": "https://memoryblock.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}
